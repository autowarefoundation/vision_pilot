# VisionPilot configuration template
#   cp config/vision_pilot.conf.example config/vision_pilot.conf

# ─── Input source ────────────────────────────────────────────────────────────
source.mode             = video
source.video_path       = ~/Downloads/data/zod/videos/001400_camera_front_blur_10fps.mp4
source.video_realtime   = true
source.video_loop       = false

source.ros2_topic       = /camera/image
source.v4l2_device      = /dev/video0
source.v4l2_fps         = 10

# ─── ONNX models ───────────────────────────────────────────────────────────────
models.autodrive_path = ~/Downloads/autodrive.onnx
models.autosteer_path = ~/Downloads/autosteer_2.0.onnx
models.autospeed_path = ~/Downloads/autospeed_2.onnx

engine.provider     = cpu
engine.precision    = fp32
engine.device_id    = 0
engine.cache_dir    = /tmp/visionpilot_trt_cache
engine.workspace_gb = 1.0

pipeline.initial_inference_check = true

# ─── Control (optional) ──────────────────────────────────────────────────────
# Off by default: when disabled the app is pure perception + display. When enabled
# it logs a ControlCommand each frame. ego_speed_mps is a placeholder until the
# vehicle-state input lands; dt_s is the control period for steering/accel shaping.
control.enabled       = false
control.ego_speed_mps = 10.0
control.dt_s          = 0.1
# ROS2 actuation output (only when built with -DENABLE_ROS2_INTERFACE=ON): the
# ControlCommand is published as ackermann_msgs/AckermannDriveStamped.
control.topic         = /control/ackermann_cmd
control.frame_id      = base_link
